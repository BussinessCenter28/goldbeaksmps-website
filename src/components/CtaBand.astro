---
import { SERVER } from '../config';
---

<section class="cta-band">
  <div class="container cta-inner">
    <h2>Ready to start your story?</h2>
    <p>Load up Minecraft, add <code class="cta-address">{SERVER.address}</code>, and join the GoldBeak world today.</p>
    <a href="#join" class="btn btn-gold btn-lg">Join {SERVER.name}</a>
  </div>
</section>
