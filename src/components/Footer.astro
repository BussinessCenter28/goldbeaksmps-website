---
import { SERVER } from '../config';
const year = new Date().getFullYear();
const [first, ...rest] = SERVER.name.split(' ');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-mark">⛏</span>
      <span class="brand-name">{first}<span class="brand-accent">{rest.join(' ')}</span></span>
    </div>
    <nav class="footer-links">
      <a href={`${base}/#join`}>Play</a>
      <a href={`${base}/#features`}>Features</a>
      <a href={`${base}/#rules`}>Rules</a>
      <a href={`${base}/#staff`}>Staff</a>
      <a href={`${base}/news/`}>News</a>
      <a href={`${base}/#faq`}>FAQ</a>
    </nav>
    <p class="footer-note">
      © {year} {SERVER.name} · {SERVER.domain} · Not affiliated with Mojang or Microsoft.
    </p>
  </div>
</footer>
