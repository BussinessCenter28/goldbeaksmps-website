---
import { getCollection } from 'astro:content';

const posts = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section" id="news">
  <div class="container">
    <h2 class="section-title">Latest News</h2>
    <p class="section-sub">Server updates, events, and announcements.</p>

    <div class="news-grid">
      {posts.map((post) => (
        <a class="news-card" href={`${base}/news/${post.id}/`}>
          {post.data.tag && <span class="news-tag">{post.data.tag}</span>}
          <h3 class="news-card-title">{post.data.title}</h3>
          <p class="news-date">{fmt(post.data.date)}</p>
          <p class="news-summary">{post.data.summary}</p>
          <span class="news-readmore">Read more →</span>
        </a>
      ))}
    </div>

    <div class="news-all">
      <a href={`${base}/news/`} class="btn btn-ghost">View all news</a>
    </div>
  </div>
</section>
