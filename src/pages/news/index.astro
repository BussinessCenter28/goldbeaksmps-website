---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="News — GoldBeak SMPS" description="The latest GoldBeak SMPS news, events, and server announcements.">
  <section class="section page-section">
    <div class="container">
      <h1 class="section-title">News &amp; Announcements</h1>
      <p class="section-sub">Everything happening on GoldBeak SMPS.</p>

      {posts.length === 0 ? (
        <p class="news-empty">No posts yet — check back soon!</p>
      ) : (
        <div class="news-list">
          {posts.map((post) => (
            <a class="news-card wide" href={`/news/${post.id}/`}>
              <div class="news-card-head">
                {post.data.tag && <span class="news-tag">{post.data.tag}</span>}
                <span class="news-date">{fmt(post.data.date)}</span>
              </div>
              <h2 class="news-card-title">{post.data.title}</h2>
              <p class="news-summary">{post.data.summary}</p>
              <span class="news-readmore">Read more →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
